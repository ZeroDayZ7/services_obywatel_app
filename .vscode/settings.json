{
  // (Explorer)
  "files.exclude": {
    "**/go.work.sum": true,
    "**/go.sum": true,
    "**/logs/": true,
    "**/bin/": true,
    // "**/": true,
    "**/.env.example": true,
    "**/.env.dev.example": true,
    "**/README.md": true,
    "**/LICENSE": true,
    "**/.gitattributes": true
  },

  // (Search)
  "search.exclude": {
    "**/go.work.sum": true,
    "**/go.sum": true,
    "**/logs/": true,
    "**/bin/": true,
    "**/.env.example": true,
    "**/.env.dev.example": true,
    "**/README.md": true,
    "**/LICENSE": true,
    "**/.gitattributes": true
  },
  "[go]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    },
    "editor.defaultFormatter": "golang.go"
  },
  "go.formatTool": "gofumpt",
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "package",
  "editor.rulers": [120, 150]
}
