# ====================================
# Project Settings
# ====================================
# Name used by Docker Compose for container grouping
COMPOSE_PROJECT_NAME=obywatel_app
DOCKER_RESTART_POLICY=no
APP_ENV=development


# ====================================
# pgAdmin Configuration
# ====================================
# Credentials for logging into pgAdmin panel
PGADMIN_DEFAULT_EMAIL=admin@example.com


# ====================================
# Primary PostgreSQL (Auth Service)
# ====================================
# Main authentication database credentials
POSTGRES_USER=admin
POSTGRES_DB=auth_database


# ====================================
# Citizen Docs PostgreSQL (Citizen-Docs Service)
# ====================================
# Separate database for document storage service
CITIZEN_DOCS_POSTGRES_USER=docs_user
CITIZEN_DOCS_POSTGRES_DB=citizen_docs


# ====================================
# Notification PostgreSQL (Notification Service)
# ====================================
# Separate database for notification service
NOTIFICATION_POSTGRES_USER=notification_user
NOTIFICATION_POSTGRES_DB=notification_database


# ====================================
# Redis Configuration
# ====================================
# Password for Redis instance (used by sessions, caching, ratelimiting, etc.)
# REDIS_PASSWORD=redispass


AUTH_DB_USER=citizen_admin
AUTH_DB_NAME=auth_db
CITIZEN_DB_USER=citizen_user
CITIZEN_DB_NAME=citizen_db
NOTIFY_DB_USER=notify_user
NOTIFY_DB_NAME=notify_db
